{
  "ReverseProxy": {
    "Routes": {
      "productos-route": {
        "ClusterId": "productos-cluster",
        "Match": { "Path": "/api/productos/{**catch-all}" },
        "Transforms": [
          {
            "RequestHeader": "X-Gateway",
            "Set": "ApiGateway"
          }
        ]
      },
      "catalogo-alias-route": {
        "ClusterId": "productos-cluster",
        "Match": { "Path": "/api/catalogo/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/productos/{**catch-all}" },
          {
            "RequestHeader": "X-Gateway",
            "Set": "ApiGateway"
          }
        ]
      },
      "ordenes-route": {
        "ClusterId": "ordenes-cluster",
        "Match": { "Path": "/api/ordenes/{**catch-all}" },
        "Transforms": [
          {
            "RequestHeader": "X-Gateway",
            "Set": "ApiGateway"
          }
        ]
      },
      "clientes-route": {
        "ClusterId": "clientes-cluster",
        "Match": { "Path": "/api/clientes/{**catch-all}" },
        "Transforms": [
          {
            "RequestHeader": "X-Gateway",
            "Set": "ApiGateway"
          }
        ]
      }
    },
    "Clusters": {
      "productos-cluster": {
        "Destinations": {
          "productos-destination": { "Address": "https://localhost:7172/" }
        }
      },
      "ordenes-cluster": {
        "Destinations": {
          "ordenes-destination": { "Address": "http://localhost:5002/" }
        }
      },
      "clientes-cluster": {
        "Destinations": {
          "clientes-destination": { "Address": "http://localhost:5003/" }
        }
      }
    }
  }
}